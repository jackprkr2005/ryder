{
  "name": "ryder-app",
  "version": "1.0.0",
  "private": true,
  "description": "Ryder — golf societies web app",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-web.mjs dist",
    "preview": "vite preview --outDir dist",
    "build:web": "node scripts/build-web.mjs",
    "ios:setup": "npm i -D @capacitor/cli @capacitor/assets && npm i @capacitor/core @capacitor/ios",
    "ios:add": "npm run build:web && npx cap add ios",
    "ios:sync": "npm run build:web && npx cap sync ios",
    "ios:icons": "npx @capacitor/assets generate --ios --assetPath resources",
    "ios:open": "npx cap open ios"
  },
  "devDependencies": {
    "vite": "^5.4.10"
  }
}
